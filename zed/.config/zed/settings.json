{
    // ========================================================================
    // UI & APPEARANCE
    // ========================================================================
    "ui_font_family": "JetBrainsMono Nerd Font Mono",
    "ui_font_size": 18,
    "theme": {
        "mode": "dark",
        "dark": "Gruvbox Dark Soft",
        "light": "Gruvbox Light Soft",
    },
    "icon_theme": "Material Icon Theme",
    "title_bar": {
        "show_branch_icon": false,
        "show_user_menu": false,
        "show_user_picture": false,
        "show_sign_in": false,
    },
    "toolbar": {
        "quick_actions": false,
    },

    // ========================================================================
    // EDITOR SETTINGS
    // ========================================================================
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "buffer_font_size": 20.0,
    "buffer_font_weight": 500.0,
    "vim_mode": true,
    "tab_size": 4,
    "format_on_save": "on",
    "relative_line_numbers": "enabled",
    "show_whitespaces": "none",
    "multi_cursor_modifier": "cmd_or_ctrl",
    "colorize_brackets": true,
    "indent_guides": {
        "enabled": true,
        "coloring": "indent_aware",
    },

    // ========================================================================
    // PANELS & NAVIGATION
    // ========================================================================
    "project_panel": {
        "dock": "right",
        "auto_fold_dirs": false,
        "default_width": 350,
    },
    "file_finder": {
        "modal_max_width": "large",
    },
    "gutter": {
        "min_line_number_digits": 0,
    },

    // ========================================================================
    // INTELLISENSE & HINTS
    // ========================================================================
    "show_signature_help_after_edits": true,
    "inlay_hints": {
        "enabled": true,
        "show_other_hints": true,
        "show_parameter_hints": true,
        "show_type_hints": true,
        "show_value_hints": true,
    },

    // ========================================================================
    // EXTENSIONS MANAGEMENT
    // ========================================================================
    "auto_install_extensions": {
        "html": true,
        "toml": true,
        "dockerfile": true,
        "sql": true,
        "material-icon-theme": true,
        "docker-compose": true,
        "angular": true,
        "dependi": true,
        "graphql": true,
        "git-firefly": true,
        "python-lsp": true,
        "justfile": true,
    },

    // ========================================================================
    // LANGUAGE-SPECIFIC SETTINGS
    // ========================================================================
    "languages": {
        "Rust": {
            "formatter": {
                "external": {
                    "command": "rustfmt",
                    "arguments": [],
                },
            },
            "format_on_save": "on",
        },
        "Python": {
            "format_on_save": "on",
            "formatter": {
                "external": {
                    "command": "ruff",
                    "arguments": ["format", "-"],
                },
            },
            "language_servers": ["pyright", "ruff"],
        },
    },

    // ========================================================================
    // LSP CONFIGURATIONS
    // ========================================================================
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "check": {
                    "command": "clippy",
                },
                "imports": {
                    "merge": { "glob": false },
                    "granularity": {
                        "enforce": true,
                        "group": "module",
                    },
                },
                "inlayHints": {
                    "maxLength": null,
                    "lifetimeElisionHints": {
                        "enable": "skip_trivial",
                        "useParameterNames": true,
                    },
                    "closureReturnTypeHints": {
                        "enable": "always",
                    },
                },
            },
        },
        "pyright": {
            "settings": {
                "python": {
                    "analysis": {
                        "typeCheckingMode": "basic", // Можно сменить на "strict" для хардкора
                        "autoImportCompletions": true,
                        "diagnosticMode": "workspace",
                    },
                },
            },
        },
        "ruff": {
            "settings": {
                "args": ["--ignore", "E501"],
            },
        },
    },

    // ========================================================================
    // ASSISTANT & AI
    // ========================================================================
    "agent_ui_font_size": 18,
    "agent_buffer_font_size": 18,

    // ========================================================================
    // PRIVACY & TELEMETRY
    // ========================================================================
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
}
